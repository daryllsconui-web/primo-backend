# ─── Required ────────────────────────────────────────────────────────────────
# Your Groq API key — obtain from https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Display name for the AI agent (non-empty string required)
AGENT_NAME=Assistant

# ─── Optional: Logging ───────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR (default: INFO)
# Use DEBUG locally for verbose output, INFO in production
LOG_LEVEL=INFO

# ─── Optional: LLM ───────────────────────────────────────────────────────────
# Groq model to use. Allowed: llama-3.3-70b-versatile | llama-3.1-8b-instant | llama-3.1-70b-versatile | gemma2-9b-it
GROQ_MODEL=llama-3.3-70b-versatile

# Agent personality descriptor (e.g. "helpful", "concise")
AGENT_PERSONALITY=helpful

# Agent tone descriptor (e.g. "friendly", "professional")
AGENT_TONE=friendly

# System prompt prepended to every conversation. Max 2000 characters.
AGENT_SYSTEM_PROMPT="You are a helpful assistant."

# ─── Optional: Admin key (knowledge base protection) ─────────────────────────
# Set a strong secret key to protect POST /ingest, GET /docs, DELETE /docs/{id}
# Requests must include header: X-Admin-Key: your-secret-key
# Leave commented out to disable protection (development only)
# ADMIN_API_KEY=your-strong-secret-key-here


# Comma-separated list of allowed origins. Use * to allow all (dev only).
CORS_ORIGINS=http://localhost:3000,https://example.com

# ─── Optional: Session TTL ───────────────────────────────────────────────────
# Minutes of inactivity before a session is automatically deleted (default: 30)
SESSION_TTL_MINUTES=30

# How often (in minutes) the cleanup task runs in the background (default: 10)
SESSION_CLEANUP_INTERVAL_MINUTES=10

# ─── Optional: Input limits ──────────────────────────────────────────────────
# Maximum characters in a single chat message (default: 2000 ≈ 400 words)
MAX_MESSAGE_CHARS=2000

# Maximum characters in the inline JSON text payload for /ingest (default: 50000)
MAX_INLINE_TEXT_CHARS=50000

# ─── Optional: RAG ───────────────────────────────────────────────────────────
# Minimum cosine similarity score for a chunk to be included in context (0–1)
SIMILARITY_THRESHOLD=0.70

# Number of top chunks to retrieve per query
TOP_K=5

# Maximum file size in megabytes per uploaded file
MAX_FILE_SIZE_MB=20

# Maximum number of files allowed in a single /ingest request
MAX_FILES_PER_REQUEST=10
